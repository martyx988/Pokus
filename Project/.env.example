APP_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokus
API_HOST=127.0.0.1
API_PORT=8000
WORKER_POLL_SECONDS=5
APP_READ_TOKEN=dev-app-token
OPERATOR_SESSION_TOKEN=dev-operator-token
ADMIN_SESSION_TOKEN=dev-admin-token

# M3.1 live source probes + combined loader credential contract.
# Keep these in your local .env only; never commit real values.
# Required for keyed source families:
EODHD_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TIINGO_API_KEY=
MARKETSTACK_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=

# Optional: improves OpenFIGI probe quota/availability, but probe can run without it.
OPENFIGI_API_KEY=
